# Copy this file to .env and fill in the values
# Never commit your real .env file to version control

# App 
NODE_ENV=development
PORT=5100
APP_NAME=Church Clerk

#  Database 
MONGO_URI=mongodb://localhost:27017/church-clerk

# Auth 
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

#  Frontend URL (for email links) 
FRONTEND_URL=http://localhost:5173

# Redis (optional — used for caching) 
# REDIS_URL=redis://localhost:6379

# Email (Resend) 
RESEND_API_KEY=re_key
FROM_NAME=Church Clerk
FROM_EMAIL=noreply@churchclerkapp.com

#  SMS (Africa's Talking) 
AT_USERNAME=sandbox
AT_API_KEY=your_africas_talking_api_key
AT_DEFAULT_SENDER_ID=ChurchClerk

# Payments (Paystack) 
PAYSTACK_MODE=test
TEST_SECRET_KEY=paystack_key
LIVE_SECRET_KEY=paystack_key
PAYSTACK_SUPPORTED_CURRENCIES=NGN,GHS,USD,ZAR

# Seeding (used only by seed.js) 
SEED_ADMIN_FULLNAME=Super Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PHONE=+2348000000000
SEED_ADMIN_PASSWORD=ChangeMe123!
